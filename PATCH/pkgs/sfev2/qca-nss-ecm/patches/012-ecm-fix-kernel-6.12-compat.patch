--- a/ecm_types.h
+++ b/ecm_types.h
@@ -10,6 +10,7 @@
 
 #include <linux/printk.h>
 #include <linux/debugfs.h>
+#include "ecm_compat.h"
 
 #if (LINUX_VERSION_CODE >= KERNEL_VERSION(6, 12, 0))
 #undef register_sysctl
--- a/ecm_db/ecm_db.c
+++ b/ecm_db/ecm_db.c
@@ -153,6 +153,37 @@ int ecm_db_per_client_routed_stats_state
 /*
  * Sysctl table header
  */
+static int ecm_db_fib_notifier_ref_count;
+
+static int ecm_db_fib_notifier_register(void)
+{
+	int ret = 0;
+
+	spin_lock_bh(&ecm_db_lock);
+	if (ecm_db_fib_notifier_ref_count == 0) {
+		ret = register_fib_notifier(&init_net, &ecm_fib_notifier, NULL, NULL);
+		if (ret) {
+			spin_unlock_bh(&ecm_db_lock);
+			return ret;
+		}
+	}
+	ecm_db_fib_notifier_ref_count++;
+	spin_unlock_bh(&ecm_db_lock);
+	return 0;
+}
+
+static void ecm_db_fib_notifier_unregister(void)
+{
+	spin_lock_bh(&ecm_db_lock);
+	if (ecm_db_fib_notifier_ref_count > 0) {
+		ecm_db_fib_notifier_ref_count--;
+		if (ecm_db_fib_notifier_ref_count == 0) {
+			unregister_fib_notifier(&init_net, &ecm_fib_notifier);
+		}
+	}
+	spin_unlock_bh(&ecm_db_lock);
+}
+
 static struct ctl_table_header *ecm_db_ctl_table_header;
 
 /*
@@ -601,7 +632,7 @@ static int ecm_db_ipv4_route_handler(con
 
 	if (ecm_db_ipv4_route_enable) {
 		ecm_front_end_ipv4_stop_temp(1);
-		ret = register_fib_notifier(&init_net, &ecm_fib_notifier, NULL, NULL);
+		ret = ecm_db_fib_notifier_register();
 		if (ret) {
 			DEBUG_ERROR("Could not register for the IPV4 routing events error:%d\n", ret);
 		}
@@ -610,7 +641,7 @@ static int ecm_db_ipv4_route_handler(con
 	}
 
 	ecm_front_end_ipv4_stop_temp(1);
-	unregister_fib_notifier(&init_net, &ecm_fib_notifier);
+	ecm_db_fib_notifier_unregister();
 	ecm_front_end_ipv4_stop_temp(0);
 
 	return ret;
